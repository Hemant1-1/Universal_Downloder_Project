##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       command line, like:
#
#           ksh gradle
#
#       Busybox and similar reduced shells will NOT work, because this script
#       requires all of these POSIX shell features:
#         * functions;
#         * expansions «$var», «${var}», «${var:-default}», «${var+prefix}», «${var=suffix}», and 
#           $(cmd) command substitution;
#         * compound commands having a testable exit status, especially «case»;
#         * various built-in commands including «command», «set», and «ulimit».
#
#   Important for patching:
#
#   (2) This script targets any POSIX shell, so it avoids extensions provided
#       by Bash, Ksh, etc; in particular arrays are avoided.
#
#       The "traditional" practice of packing multiple parameters into a space-separated string is a well-documented source of bugs and security
#       problems, so this is (mostly) avoided, by progressively accumulating options in "$@", and eventually passing that to Java.
#
#       Where the inherited environment variables (DEFAULT_JVM_OPTS, JAVA_OPTS, and GRADLE_OPTS) rely on word-splitting, this is performed explicitly;
#       see the in-line comments for details.
#
#       There are tweaks for specific operating systems such as AIX, CygWin, Darwin (MacOS), and FreeBSD.
#
#   (3) This script is generated from the Groovy template
#       https://github.com/gradle/gradle/blob/HEAD/subprojects/launcher/src/main/resources/org/gradle/launcher/scripts/gradlew
#
#       The template download method not used, because a binary repair script has not yet been written.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}  # leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*" -> "}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

# This is normally unused
# shellcheck disable=SC2034
APP_BASE_NAME=${app_path##*/}
# Discard cd standard output in case $CDPATH is set (https://github.com/gradle/gradle/issues/25036)
APP_HOME=$( cd -P "${APP_HOME:-./}" > /dev/null && printf '%s
' "$PWD" ) || exit

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in                #(
  CYGWIN* )         cygwin=true  ;; #(
  Darwin* )         darwin=true  ;; #(
  MSYS* | MINGW* )  msys=true    ;; #(
  NONSTOP* )        nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar


# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        # In POSIX sh, ulimit -H is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        # In POSIX sh, ulimit -n is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order to eventually pass to the exec'd java command.
# Note the there is currently no way to achieve this 100% shell-proof, the $(printf '%s\n' "$@") is the best we can do.

# Collect all arguments for the java command, stacking in reverse order to eventually pass to the exec'd java command.
# Note there is currently no way to achieve this 100% shell-proof, the `( ... )` command substitution is the best we can do.
# Many Gradle utilities assume POSIX and rely on the `( ... )` command substitution to enumerate arguments.

# The command line length is limited to avoid command line overflow attacks.
# This works around the issue by breaking the argument list into multiple exec'ed commands.

# The pseudo arguments have to be manually maintained and correspond to the GROOVY template and
# the Gradle Bootstrap class' option handling.

# 1) Collect all arguments that start with "-D", and treat them as environment variables.
# 2) Apply a subcommand if required.
# 3) Collect all arguments starting with "-P" (project properties), and treat them as parameters to be passed to Java to set via "-D" options.
# 4) Collect all remaining arguments into the variable 'args' to be passed to the Java command's classpath.

# Resolve arguments by reversing the list, stacking arguments until we find a recognized bootstrap class.
# The first argument is likely the main class. Keep it separate for now.
mainClass=$1
shift

# The rest of the arguments are stored in reverse order.
args=""
for i in "$@"; do
  case $i in
    -D*)
      JAVA_OPTS="$JAVA_OPTS \"$i\""
      ;;
    -P*)
      PROJECT_OPTS="$PROJECT_OPTS \"$i\""
      ;;
    *)
      args="\"$i\" $args"
      ;;
  esac
done

# Prepend APP_NAME and APP_BASE_NAME environment variables to the args (if not already present).
if [ -z "$APP_NAME" ]; then
    APP_NAME=$( basename "$0" )
    APP_NAME=${APP_NAME%.*}
    export APP_NAME
fi
if [ -z "$APP_BASE_NAME" ]; then
    APP_BASE_NAME=$( basename "$0" )
    export APP_BASE_NAME
fi

# Add in the environment variables, CLASSPATH, and the project properties.
set -- "$mainClass" \
      -classpath "$CLASSPATH" \
      -Dorg.gradle.appname="$APP_BASE_NAME" \
      $GRADLE_OPTS \
      $JAVA_OPTS \
      $PROJECT_OPTS \
      "$args"

# Use eval to expand the arguments in a safe way.
eval exec "\"$JAVACMD\"" "$@"

# Create a secure temporary directory for storing the args list.
# This is done to avoid command line overflow issues.
# Note: mktemp is not available on all platforms.
if command -v mktemp > /dev/null; then
    TMP_DIR=$(mktemp -d)
    export TMP_DIR
else
    TMP_DIR=/tmp
fi

# Write the args list to a file in the temporary directory.
ARGS_FILE="$TMP_DIR/gradle-args-$$.txt"
printf '%s\n' "$@" > "$ARGS_FILE"

# Execute the Java command with the args file.
exec "$JAVACMD" "@$ARGS_FILE"

# Clean up the temporary directory.
trap 'rm -rf "$TMP_DIR"' EXIT
